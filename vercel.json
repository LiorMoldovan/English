{
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*\\.(js|css|svg|json|png|ico|webmanifest))", "destination": "/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
